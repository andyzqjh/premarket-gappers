GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

AI_PROVIDER_ORDER=openrouter,gemini,openai,anthropic
OPENROUTER_MODEL=openai/gpt-5.4-mini
OPENROUTER_MODEL_CANDIDATES=openai/gpt-5.4-mini,google/gemini-2.5-flash-lite,qwen/qwen3-30b-a3b,deepseek/deepseek-chat-v3-0324
OPENROUTER_MAX_CONCURRENCY=1
OPENROUTER_TIMEOUT_SECONDS=90

OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514

APP_TIMEZONE=Asia/Singapore
AUTO_REFRESH_SECONDS=60

OBSIDIAN_EXPORT_ENABLED=1
OBSIDIAN_EXPORT_TRIGGER_ORIGINS=view,manual,scheduled
OBSIDIAN_EXPORT_BOARD_KINDS=watchlist,premarket,market-brief

SCHEDULED_SCAN_ENABLED=1
SCHEDULED_SCAN_TIMES=08:30,20:30
SCHEDULED_SCAN_BOARD_KINDS=premarket,watchlist,market-brief
SCHEDULED_SCAN_STAGGER_SECONDS=8

APP_HOST=127.0.0.1
APP_PORT=5000
